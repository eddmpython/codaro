{
  "$schema": "./tokens.schema.json",
  "version": 1,
  "astryx": {
    "core": "0.1.6",
    "themeNeutral": "0.1.6",
    "cli": "0.1.6",
    "stylex": "0.19.0",
    "themeName": "codaro"
  },
  "semanticRoles": {
    "canvas": "--color-background-body",
    "surface": "--color-background-surface",
    "elevated": "--color-background-card",
    "popover": "--color-background-popover",
    "mutedSurface": "--color-background-muted",
    "textPrimary": "--color-text-primary",
    "textSecondary": "--color-text-secondary",
    "border": "--color-border",
    "focus": "--color-accent",
    "brand": "--color-accent",
    "success": "--color-success",
    "warning": "--color-warning",
    "danger": "--color-error",
    "info": "--color-text-blue",
    "code": "--color-background-muted"
  },
  "astryxTokens": {
    "--color-background-surface": ["#ffffff", "#222327"],
    "--color-background-body": ["#f5f6f8", "#151619"],
    "--color-background-card": ["#ffffff", "#1b1c20"],
    "--color-background-popover": ["#ffffff", "#24262a"],
    "--color-background-muted": ["#eceff3", "#202226"],
    "--color-accent": ["#6d2857", "#e4a9d2"],
    "--color-accent-muted": ["#f5e8f1", "#3b2635"],
    "--color-neutral": ["#17171b0d", "#ffffff14"],
    "--color-overlay": ["#17171b8a", "#000000c7"],
    "--color-overlay-hover": ["#17171b0a", "#ffffff0d"],
    "--color-overlay-pressed": ["#17171b14", "#ffffff17"],
    "--color-text-primary": ["#18191d", "#f5f6f8"],
    "--color-text-secondary": ["#5d626d", "#aeb3bd"],
    "--color-text-disabled": ["#979ca5", "#666b74"],
    "--color-text-accent": ["#6d2857", "#e4a9d2"],
    "--color-on-dark": "#ffffff",
    "--color-on-light": "#18191d",
    "--color-on-accent": ["#ffffff", "#24141f"],
    "--color-on-success": ["#ffffff", "#10201e"],
    "--color-on-error": ["#ffffff", "#2b1417"],
    "--color-on-warning": "#251a08",
    "--color-icon-primary": ["#282a30", "#eceef2"],
    "--color-icon-secondary": ["#686d77", "#aeb3bd"],
    "--color-icon-disabled": ["#a3a7af", "#5d626b"],
    "--color-icon-accent": ["#6d2857", "#e4a9d2"],
    "--color-success": ["#08786a", "#79d8c8"],
    "--color-success-muted": ["#d9f2ed", "#163a35"],
    "--color-warning": ["#855600", "#f1c36d"],
    "--color-warning-muted": ["#f8eccf", "#3e3017"],
    "--color-error": ["#b3263b", "#ffabb5"],
    "--color-error-muted": ["#f9e1e5", "#422127"],
    "--color-border": ["#d9dde3", "#34373d"],
    "--color-border-emphasized": ["#b7bdc7", "#535760"],
    "--color-skeleton": ["#dfe2e7", "#3b3e45"],
    "--color-shadow": ["#17171b1f", "#00000066"],
    "--color-tint-hover": ["#17171b", "#ffffff"],
    "--color-background-blue": ["#e2edff", "#1e304d"],
    "--color-border-blue": ["#a8c7f5", "#496d9f"],
    "--color-icon-blue": ["#1559aa", "#8db9ff"],
    "--color-text-blue": ["#154f95", "#a7c9ff"],
    "--color-background-teal": ["#d9f2ed", "#163a35"],
    "--color-border-teal": ["#9bd5ca", "#3e796f"],
    "--color-icon-teal": ["#08786a", "#79d8c8"],
    "--color-text-teal": ["#075f55", "#9ce7dc"],
    "--color-background-purple": ["#f5e8f1", "#3b2635"],
    "--color-border-purple": ["#d8b2cc", "#835a77"],
    "--color-icon-purple": ["#7c3565", "#e4a9d2"],
    "--color-text-purple": ["#6d2857", "#edc2df"],
    "--color-background-orange": ["#f9ead9", "#422d1b"],
    "--color-border-orange": ["#e4bd91", "#93643b"],
    "--color-icon-orange": ["#a8560b", "#eda95e"],
    "--color-text-orange": ["#8d4608", "#f3bd82"],
    "--spacing-0": "0px",
    "--spacing-0-5": "2px",
    "--spacing-1": "4px",
    "--spacing-1-5": "6px",
    "--spacing-2": "8px",
    "--spacing-3": "12px",
    "--spacing-4": "16px",
    "--spacing-5": "20px",
    "--spacing-6": "24px",
    "--spacing-7": "28px",
    "--spacing-8": "32px",
    "--spacing-9": "36px",
    "--spacing-10": "40px",
    "--spacing-11": "44px",
    "--spacing-12": "48px",
    "--size-element-sm": "28px",
    "--size-element-md": "34px",
    "--size-element-lg": "40px",
    "--radius-none": "0px",
    "--radius-inner": "3px",
    "--radius-element": "6px",
    "--radius-container": "8px",
    "--radius-page": "8px",
    "--radius-full": "9999px",
    "--duration-fast": "120ms",
    "--duration-medium": "180ms",
    "--duration-slow": "240ms",
    "--shadow-low": "0 1px 2px light-dark(#17171b0d, #00000033), 0 4px 12px light-dark(#17171b0a, #00000029)",
    "--shadow-med": "0 2px 5px light-dark(#17171b12, #00000040), 0 12px 28px light-dark(#17171b12, #00000038)",
    "--shadow-high": "0 8px 20px light-dark(#17171b17, #00000052), 0 28px 64px light-dark(#17171b1f, #00000047)"
  },
  "typography": {
    "scale": {"base": 15, "ratio": 1.2},
    "body": {
      "family": "Pretendard",
      "fallbacks": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif",
      "weight": "normal"
    },
    "heading": {
      "family": "Space Grotesk",
      "fallbacks": "Pretendard, ui-sans-serif, system-ui, sans-serif",
      "weight": "semibold",
      "weights": {"1": "bold", "2": "bold", "3": "semibold", "4": "semibold"}
    },
    "code": {
      "family": "JetBrains Mono",
      "fallbacks": "SFMono-Regular, Consolas, Liberation Mono, monospace",
      "weight": "normal"
    }
  },
  "motion": {"fast": 120, "medium": 180, "slow": 240, "ratio": 0.75},
  "radius": {"base": 4, "multiplier": 1},
  "syntax": {
    "name": "codaro-syntax",
    "tokens": {
      "keyword": ["#7d2d65", "#efb8df"],
      "string": ["#087263", "#88dfd0"],
      "comment": ["#737985", "#8c929d"],
      "number": ["#a34f08", "#f0b272"],
      "function": ["#1c5eac", "#99c2ff"],
      "type": ["#6d2857", "#e4a9d2"],
      "variable": ["#24262b", "#eceef2"],
      "operator": ["#626873", "#b3b8c1"],
      "constant": ["#96500f", "#eeb77d"],
      "tag": ["#a4293a", "#ffb1ba"],
      "attribute": ["#7b5b00", "#e8c66d"],
      "property": ["#086c60", "#8adfd2"],
      "punctuation": ["#858b95", "#747a84"],
      "background": ["#f8f9fa", "#17181b"]
    }
  },
  "density": {
    "public": {
      "--size-element-sm": "32px",
      "--size-element-md": "38px",
      "--size-element-lg": "44px"
    },
    "learningComfortable": {
      "--size-element-sm": "32px",
      "--size-element-md": "38px",
      "--size-element-lg": "44px"
    },
    "studioDense": {
      "--size-element-sm": "28px",
      "--size-element-md": "32px",
      "--size-element-lg": "36px"
    }
  },
  "accents": {
    "plum": {
      "accent": ["#6d2857", "#e4a9d2"],
      "muted": ["#f5e8f1", "#3b2635"],
      "onAccent": ["#ffffff", "#24141f"]
    },
    "blue": {
      "accent": ["#1559aa", "#8db9ff"],
      "muted": ["#e2edff", "#1e304d"],
      "onAccent": ["#ffffff", "#142238"]
    },
    "teal": {
      "accent": ["#08786a", "#79d8c8"],
      "muted": ["#d9f2ed", "#163a35"],
      "onAccent": ["#ffffff", "#10201e"]
    }
  }
}
