{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codaro.dev/contracts/artifactOwnership.schema.json",
  "title": "Codaro Artifact Ownership",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifacts"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ArtifactOwner" }
    }
  },
  "$defs": {
    "ArtifactRole": {
      "type": "string",
      "enum": ["source", "generated", "packaged", "evidence"]
    },
    "ArtifactOwner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactId", "role", "owner", "sourcePath", "surfacePaths"],
      "properties": {
        "artifactId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "role": { "$ref": "#/$defs/ArtifactRole" },
        "owner": { "type": "string", "minLength": 1 },
        "sourcePath": { "type": "string", "minLength": 1 },
        "surfacePaths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
