{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codaro.dev/contracts/tableArtifactDescriptor.schema.json",
  "title": "Codaro Table Artifact Descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "origin",
    "path",
    "format",
    "byteLength",
    "contentHash",
    "rowCount",
    "columnCount",
    "columns"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "table" },
    "origin": { "enum": ["created", "fixture"] },
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*:).+$"
    },
    "format": { "enum": ["csv", "json"] },
    "byteLength": { "type": "integer", "minimum": 0 },
    "contentHash": { "type": "string", "pattern": "^sha256-[A-Za-z0-9_-]{43}$" },
    "rowCount": { "type": "integer", "minimum": 0 },
    "columnCount": { "type": "integer", "minimum": 1 },
    "columns": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
